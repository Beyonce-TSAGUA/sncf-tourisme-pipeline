# Copier ce fichier en .env et remplir les valeurs réelles
# Ne JAMAIS commiter le fichier .env

# MinIO
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=

# PostgreSQL (Airflow)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=
POSTGRES_DB=airflow

# Airflow
# Générer avec : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=
AIRFLOW_WEBSERVER_SECRET_KEY=

# API SNCF (optionnel selon les endpoints)
SNCF_API_KEY=